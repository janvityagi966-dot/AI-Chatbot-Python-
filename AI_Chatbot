import datetime
import time

name = input("Welcome, enter your name : ")
presentHour = datetime.datetime.now().hour

if 5 <= presentHour <= 11:
    print("Good morning,", name)
elif 11 <= presentHour <= 17:
    print("Good afternoon,", name)
elif 17 <= presentHour <= 20:
    print("Good evening,", name)
else:
    print("Good night,", name)

print("Hello, Welcome to Your ChatBot")
print("You can ask me basic question, Type 'bye' to exit from the bot")

responses = {
    "hello": "Hi, welcome. How can I help you?",
    "how are you": "I am very fine. Thank you",
    "who are you": "I am smart AI chatbot",
    "motivate me": "Keep going. Every bug makes you a better coder ",
    "happy": "Great to hear that"
}

def getResponseBot(userQuestion):
    userQuestion = userQuestion.lower().strip()

    for eachKey in responses:
        cleanKey = eachKey.lower().strip()
        if cleanKey == userQuestion:
            return responses[eachKey]

    for eachKey in responses:
        cleanKey = eachKey.lower().strip()
        if cleanKey in userQuestion:
            return responses[eachKey]

    return "I am not able to tell that yet. I will learn it as soon as Possible"

while True:
    userInput = input("Please ask your question: ")

    if userInput.lower().strip() == "bye": # Exact 'bye' check kiya
        print("Bot Response: Nice to help you \n come again whenever you need")
        time.sleep(1)
        break

    reply = getResponseBot(userInput)
    print("Bot Response:", reply)